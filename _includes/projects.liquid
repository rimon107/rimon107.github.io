<div class="col">
  <a href="{% if project.redirect %}{{ project.redirect }}{% else %}{{ project.url | relative_url }}{% endif %}">
    <div class="card h-100 hoverable d-flex flex-column">
      {% if project.img %}
        <div class="card-img-wrapper" style="aspect-ratio: 16/9; overflow: hidden; background: #f8f9fa; display: flex; align-items: center; justify-content: center;">
          {%
            include figure.liquid
            loading="eager"
            path=project.img
            sizes="250px"
            alt="project thumbnail"
            class="card-img-top"
            cover=true
          %}
        </div>
      {% endif %}
      <div class="card-body d-flex flex-column">
        {% if project.year %}
          <p class="mb-1" style="color: var(--global-theme-color); font-size: 0.85rem; font-weight: 600; letter-spacing: 0.05em;">
            {{ project.year }}
          </p>
        {% endif %}
        <h3 class="card-title" style="min-height: 2.5em; font-size: 1.25rem; font-weight: 600; margin-bottom: 0.5rem;">{{ project.title }}</h3>
        <p class="card-text">{{ project.description }}</p>
        <div class="row ml-1 mr-1 p-0 mt-auto">
          {% if project.github %}
            <div class="github-icon">
              <div class="icon" data-toggle="tooltip" title="Code Repository">
                <a href="{{ project.github }}"><i class="fa-brands fa-github gh-icon"></i></a>
              </div>
              {% if project.github_stars %}
                <span class="stars" data-toggle="tooltip" title="GitHub Stars">
                  <i class="fa-solid fa-star"></i>
                  <span id="{{ project.github_stars }}-stars"></span>
                </span>
              {% endif %}
            </div>
          {% endif %}
        </div>
      </div>
    </div>
  </a>
</div>
